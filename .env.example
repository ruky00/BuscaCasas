# === BuscaCasas - Configuracion ===

# Busqueda
SEARCH_LOCATION=madrid
MAX_PAGES=3

# Email (SMTP)
# Gmail: smtp.gmail.com:587 (necesita App Password, no contrasena normal)
# Outlook: smtp.office365.com:587
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=tu_email@gmail.com
SENDER_PASSWORD=tu_app_password_de_gmail
RECIPIENT_EMAIL=destinatario@email.com

# Scoring
MIN_SCORE=3.5
MAX_EMAIL_RESULTS=10

# Salida
OUTPUT_DIR=data

# Scrapers activos (separados por coma)
ACTIVE_SCRAPERS=fotocasa,pisos,redpiso
